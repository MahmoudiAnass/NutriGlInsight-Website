# Copy this file to .env.local and fill in real values.

# Resend API key — used by the /api/delete-request route to email deletion requests.
# Get one at https://resend.com/api-keys
RESEND_API_KEY=

# Verified sender address in your Resend account (e.g. no-reply@nutriglinsight.com).
# Must be on a domain you have verified in Resend.
DELETE_REQUEST_FROM="NutriGL Insight <no-reply@nutriglinsight.com>"

# Where deletion requests are delivered.
DELETE_REQUEST_TO=contact@nutriglinsight.com

# Public site URL (used for canonical URLs, sitemap, OG tags).
NEXT_PUBLIC_SITE_URL=https://nutriglinsight.com
